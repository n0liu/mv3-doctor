{
  "name": "mv3-doctor",
  "version": "0.1.0",
  "description": "Diagnose Chrome Manifest V3 extension pitfalls — and teach AI coding agents to avoid them.",
  "type": "module",
  "license": "MIT",
  "author": "n0liu (https://github.com/n0liu)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/n0liu/mv3-doctor.git"
  },
  "homepage": "https://github.com/n0liu/mv3-doctor#readme",
  "bugs": "https://github.com/n0liu/mv3-doctor/issues",
  "bin": {
    "mv3-doctor": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "SKILL.md",
    "references"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test --ignore-pattern='test/fixtures/**' --deny-warnings",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage --coverage.provider=v8 --coverage.include='src/**' --coverage.exclude='src/cli.ts' --coverage.thresholds.lines=85 --coverage.thresholds.statements=85 --coverage.thresholds.functions=90 --coverage.thresholds.branches=65"
  },
  "keywords": [
    "chrome-extension",
    "manifest-v3",
    "mv3",
    "lint",
    "linter",
    "service-worker",
    "browser-extension",
    "claude",
    "ai-agent",
    "skill"
  ],
  "dependencies": {
    "acorn": "^8.17.0",
    "acorn-walk": "^8.3.5",
    "eslint-scope": "^9.1.2"
  },
  "devDependencies": {
    "@types/estree": "^1.0.9",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "oxlint": "^1.74.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
