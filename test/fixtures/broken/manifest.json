{
  "manifest_version": 3,
  "name": "Deliberately Broken Extension",
  "version": "1.0.0",
  "browser_action": {
    "default_title": "Left over from Manifest V2"
  },
  "background": {
    "service_worker": "background.js",
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["https://example.com/*"],
      "js": ["content.js"]
    }
  ],
  "permissions": ["storage", "webRequestBlocking"],
  "host_permissions": ["<all_urls>"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' https://cdn.example.com; object-src 'self'"
  }
}
